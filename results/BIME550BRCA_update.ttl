            owl:intersectionOf ( :Patient [ a owl:Class ;
                        owl:unionOf ( [ a owl:Class ;
                                    owl:intersectionOf ( [ a owl:Class ;
                                                owl:complementOf [ a owl:Restriction ;
                                                        owl:onProperty :hasUpregulatedPathway ;
                                                        owl:someValuesFrom :ER-related_pathway ] ] [ a owl:Class ;
                                                owl:complementOf [ a owl:Restriction ;
                                                        owl:onProperty :hasUpregulatedPathway ;
                                                        owl:someValuesFrom :PR-related_pathway ] ] [ a owl:Restriction ;
                                                owl:onProperty :hasUpregulatedPathway ;
                                                owl:someValuesFrom :Ki-67-related_pathway ] ) ] [ a owl:Class ;
                                    owl:intersectionOf ( [ a owl:Class ;
                                                owl:complementOf [ a owl:Restriction ;
                                                        owl:onProperty :hasUpregulatedPathway ;
                                                        owl:someValuesFrom :Ki-67-related_pathway ] ] [ a owl:Restriction ;
                                                owl:onProperty :hasUpregulatedPathway ;
                                                owl:someValuesFrom :ER-related_pathway ] ) ] ) ] [ a owl:Restriction ;
                        owl:onProperty :hasUpregulatedPathway ;
                        owl:someValuesFrom :HER2-related_pathway ] ) ] .

