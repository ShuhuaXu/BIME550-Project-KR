:downregulatesPathway a owl:ObjectProperty ;
    rdfs:domain <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> ;
    rdfs:range <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasGoFMutation a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasMutation .

:hasLoFMutation a owl:ObjectProperty ;
    rdfs:subPropertyOf :hasMutation .

:isGoFMutationOf a owl:ObjectProperty ;
    owl:inverseOf :hasGoFMutation .

:isLoFMutationOf a owl:ObjectProperty ;
    owl:inverseOf :hasLoFMutation .

:upregulatesPathway a owl:ObjectProperty ;
    rdfs:domain <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> ;
    rdfs:range <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> ;
    rdfs:subPropertyOf owl:topObjectProperty .

