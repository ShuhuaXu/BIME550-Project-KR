@prefix : <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.semanticweb.org/kevinlee/ontologies/2026/1/BIME550BRCA> a owl:Ontology .

:Normal a owl:Class ;
    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Patient [ a owl:Class ;
                        owl:complementOf [ a owl:Class ;
                                owl:unionOf ( :Basal :Her2 :LumA :LumB ) ] ] ) ] .

:Others a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation>,
        owl:NamedIndividual .

:Patient_Basal_Demo a :Patient,
        owl:NamedIndividual ;
    rdfs:label "Demo Patient - Expected Basal" ;
    :hasMutation :BRCA1_p.C61G,
        :TP53_p.R342P .

:Patient_Her2_Demo a :Patient,
        owl:NamedIndividual ;
    rdfs:label "Demo Patient - Expected Her2" ;
    :hasMutation :ERBB2_p.V777L .

:Patient_LumA_Demo a :Patient,
        owl:NamedIndividual ;
    rdfs:label "Demo Patient - Expected LumA" ;
    :hasMutation :PIK3CA_p.H1047R .

:Patient_LumB_Demo a :Patient,
        owl:NamedIndividual ;
    rdfs:label "Demo Patient - Expected LumB" ;
    :hasMutation :ERBB2_p.S310F,
        :PIK3CA_p.E545K .

:Patient_Normal_Demo a :Patient,
        owl:NamedIndividual ;
    rdfs:label "Demo Patient - Expected Normal" ;
    :hasMutation :PTEN_p.R130Q .

:hasDownregulatedPathway a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    owl:propertyChainAxiom ( :hasMutation :downregulatesPathway ) .

:hasEffect a owl:ObjectProperty ;
    rdfs:domain <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> ;
    rdfs:range :Mutation_Effect ;
    rdfs:subPropertyOf owl:topObjectProperty .

:hasGoF a owl:ObjectProperty ;
    rdfs:domain :Patient ;
    rdfs:range <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> ;
    owl:propertyChainAxiom ( :hasMutation :isGoFMutationOf ) .

:AKT1 a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene>,
        :AKT1,
        owl:Class,
        owl:NamedIndividual ;
    :hasGoFMutation :AKT1_p.E17K ;
    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .

:AKT1_p.E17K a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation>,
        owl:NamedIndividual ;
    rdfs:label "AKT1 p.E17K" ;
    :hasEffect :GoF ;
    :upregulatesPathway :Constitutive_Signaling_by_AKT1_E17K_in_Cancer .

:BRCA2 a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene>,
        :BRCA2,
        owl:Class,
        owl:NamedIndividual ;
    :hasLoFMutation :BRCA2_p.Y3308Ter ;
    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .

:BRCA2_p.Y3308Ter a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation>,
        owl:NamedIndividual ;
    rdfs:label "BRCA2 p.Y3308*" ;
    :downregulatesPathway :Defective_Homologous_Recombination_Repair ;
    :hasEffect :LoF .

:Basal a owl:Class ;
    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Patient [ a owl:Restriction ;
                        owl:onProperty :hasLoF ;
                        owl:someValuesFrom :BRCA1 ] [ a owl:Restriction ;
                        owl:onProperty :hasLoF ;
                        owl:someValuesFrom :TP53 ] [ a owl:Restriction ;
                        owl:onProperty :hasUpregulatedPathway ;
                        owl:someValuesFrom :Ki-67-related_pathway ] ) ] .

:Cell_Proliferation_due_to_TP53_Loss a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway>,
        :Ki-67-related_pathway,
        owl:NamedIndividual ;
    rdfs:label "Cell Proliferation due to TP53 Loss" .

:Constitutive_Signaling_by_AKT1_E17K_in_Cancer a <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway>,
        :ER-related_pathway,
