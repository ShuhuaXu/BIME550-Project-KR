@prefix : <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/> .

<http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/affectsPathway
:affectsPathway rdf:type owl:ObjectProperty ;
                rdfs:domain :Mutation ;
                rdfs:range :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/downregulatesPathway
:downregulatesPathway rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :affectsPathway ,
                                         owl:topObjectProperty ;
                      rdfs:domain :Mutation ;
                      rdfs:range :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasDownregulatedPathway
:hasDownregulatedPathway rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty ;
                         rdfs:domain :Patient ;
                         rdfs:range :Pathway ;
                         owl:propertyChainAxiom ( :hasMutation
                                                  :downregulatesPathway
                                                ) .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasEffect
:hasEffect rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain :Mutation ;
           rdfs:range :Mutation_Effect .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasGoF
:hasGoF rdf:type owl:ObjectProperty ;
        rdfs:domain :Patient ;
        rdfs:range :Gene ;
        owl:propertyChainAxiom ( :hasMutation
                                 :isGoFMutationOf
                               ) .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasGoFMutation
:hasGoFMutation rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasMutation ;
                owl:inverseOf :isGoFMutationOf .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasLoF
:hasLoF rdf:type owl:ObjectProperty ;
        rdfs:domain :Patient ;
        rdfs:range :Gene ;
        owl:propertyChainAxiom ( :hasMutation
                                 :isLoFMutationOf
                               ) .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasLoFMutation
:hasLoFMutation rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :hasMutation ;
                owl:inverseOf :isLoFMutationOf .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasMutation
:hasMutation rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain :Patient ;
             owl:propertyDisjointWith :notHasMutation .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasUpregulatedPathway
:hasUpregulatedPathway rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdfs:domain :Patient ;
                       rdfs:range :PathwayCategory ;
                       owl:propertyChainAxiom ( :hasMutation
                                                :upregulatesPathway
                                              ) .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/isGoFMutationOf
:isGoFMutationOf rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/isLoFMutationOf
:isLoFMutationOf rdf:type owl:ObjectProperty .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/notHasMutation
:notHasMutation rdf:type owl:ObjectProperty ;
                rdfs:domain :Patient ;
                rdfs:range :Mutation .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/upregulatesPathway
:upregulatesPathway rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :affectsPathway ,
                                       owl:topObjectProperty ;
                    rdfs:domain :Mutation ;
                    rdfs:range :Pathway .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/owl/owlapi/turtle#hasDownregulatedPathway
<http://www.semanticweb.org/owl/owlapi/turtle#hasDownregulatedPathway> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/owl/owlapi/turtle#hasNormallyRegulatedPathway
<http://www.semanticweb.org/owl/owlapi/turtle#hasNormallyRegulatedPathway> rdf:type owl:DatatypeProperty .


###  http://www.semanticweb.org/owl/owlapi/turtle#hasUpregulatedPathway
<http://www.semanticweb.org/owl/owlapi/turtle#hasUpregulatedPathway> rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#ER-Normal
:ER-Normal rdf:type owl:Class ;
           owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :AKT1_p.E17K
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.E542K
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.E545A
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.E545G
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.E545K
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.H1047L
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.H1047R
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.H1047Y
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.M1043I
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.Q546K
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PIK3CA_p.Q546R
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PTEN_p.Q149_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PTEN_p.R130P
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PTEN_p.R130Q
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PTEN_p.S287_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PTEN_p.S59_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :PTEN_p.Y88_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :RB1_p.A74Efs_4
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :RB1_p.R455_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :RB1_p.R552_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :RB1_p.S215_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :RB1_p.S829_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :SMAD4_p.E526_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :SMAD4_p.Q245_
                                                      ]
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty :notHasMutation ;
                                                        owl:hasValue :SMAD4_p.Q334_
                                                      ]
                                                    ) ;
                                 rdf:type owl:Class
                               ] ;
           rdfs:subClassOf :Patient .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#HER2-Normal
:HER2-Normal rdf:type owl:Class ;
             owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.D769H
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.D769Y
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.G309A
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.I767M
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.L755M
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.L755S
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.L755W
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.R678Q
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.S310F
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.V777L
                                                        ]
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty :notHasMutation ;
                                                          owl:hasValue :ERBB2_p.V842I
                                                        ]
                                                      ) ;
                                   rdf:type owl:Class
                                 ] ;
             rdfs:subClassOf :Patient .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Ki-67-Normal
:Ki-67-Normal rdf:type owl:Class ;
              owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                         [ rdf:type owl:Restriction ;
                                                           owl:onProperty :notHasMutation ;
                                                           owl:hasValue :TP53_p.R342P
                                                         ]
                                                       ) ;
                                    rdf:type owl:Class
                                  ] ;
              rdfs:subClassOf :Patient .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/AKT1
:AKT1 rdf:type owl:Class ;
      rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA1
:BRCA1 rdf:type owl:Class ;
       rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA2
:BRCA2 rdf:type owl:Class ;
       rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Basal
:Basal rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :ER-Normal
                                                  :HER2-Normal
                                                  :Patient
                                                  [ rdf:type owl:Class ;
                                                    owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasLoF ;
                                                                    owl:someValuesFrom :BRCA1
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasLoF ;
                                                                    owl:someValuesFrom :BRCA2
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasLoF ;
                                                                    owl:someValuesFrom :TP53
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasUpregulatedPathway ;
                                                                    owl:someValuesFrom :Ki-67-related_pathway
                                                                  ]
                                                                )
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf :BreastCancerSubType .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BreastCancerSubType
:BreastCancerSubType rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/DNA_Repair_Pathway
:DNA_Repair_Pathway rdf:type owl:Class ;
                    rdfs:subClassOf :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/ER
:ER rdf:type owl:Class ;
    rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/ER-related_pathway
:ER-related_pathway rdf:type owl:Class ;
                    rdfs:subClassOf :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/ERBB2
:ERBB2 rdf:type owl:Class ;
       rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Gene
:Gene rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/HER2-related_pathway
:HER2-related_pathway rdf:type owl:Class ;
                      rdfs:subClassOf :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Her2
:Her2 rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :ER-Normal
                                                 :Patient
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :HER2-related_pathway
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf :BreastCancerSubType .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Ki-67
:Ki-67 rdf:type owl:Class ;
       rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Ki-67-related_pathway
:Ki-67-related_pathway rdf:type owl:Class ;
                       rdfs:subClassOf :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/LumA
:LumA rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :HER2-Normal
                                                 :Ki-67-Normal
                                                 :Patient
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :ER-related_pathway
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf :BreastCancerSubType .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/LumB
:LumB rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                 [ rdf:type owl:Class ;
                                                   owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :hasUpregulatedPathway ;
                                                                   owl:someValuesFrom :HER2-related_pathway
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :hasUpregulatedPathway ;
                                                                   owl:someValuesFrom :Ki-67-related_pathway
                                                                 ]
                                                               )
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :ER-related_pathway
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf :BreastCancerSubType .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Mutation
:Mutation rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Mutation_Effect
:Mutation_Effect rdf:type owl:Class ;
                 rdfs:subClassOf :Mutation .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Normal
:Normal rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :ER-Normal
                                                   :HER2-Normal
                                                   :Ki-67-Normal
                                                   :Patient
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :notHasMutation ;
                                                     owl:hasValue :BRCA1_p.C61G
                                                   ]
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty :notHasMutation ;
                                                     owl:hasValue :BRCA2_p.Y3308Ter
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf :BreastCancerSubType .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PIK3CA
:PIK3CA rdf:type owl:Class ;
        rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PR
:PR rdf:type owl:Class ;
    rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PR-related_pathway
:PR-related_pathway rdf:type owl:Class ;
                    rdfs:subClassOf :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PTEN
:PTEN rdf:type owl:Class ;
      rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Pathway
:Pathway rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PathwayCategory
:PathwayCategory rdf:type owl:Class ;
                 owl:equivalentClass [ rdf:type owl:Class ;
                                       owl:unionOf ( :ER-related_pathway
                                                     :HER2-related_pathway
                                                     :Ki-67-related_pathway
                                                     :PR-related_pathway
                                                   )
                                     ] ;
                 rdfs:subClassOf :Pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Patient
:Patient rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :hasUpregulatedPathway ;
                           owl:allValuesFrom :PathwayCategory
                         ] .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/RB1
:RB1 rdf:type owl:Class ;
     rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/SMAD4
:SMAD4 rdf:type owl:Class ;
       rdfs:subClassOf :Gene .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/TP53
:TP53 rdf:type owl:Class ;
      rdfs:subClassOf :Gene .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/AKT1
:AKT1 rdf:type owl:NamedIndividual ,
               :AKT1 ,
               :Gene ;
      :hasGoFMutation :AKT1_p.E17K .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/AKT1_p.E17K
:AKT1_p.E17K rdf:type owl:NamedIndividual ,
                      :Mutation ;
             :hasEffect :GoF ;
             :upregulatesPathway :Constitutive_Signaling_by_AKT1_E17K_in_Cancer ;
             rdfs:label "AKT1 p.E17K" .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA1
:BRCA1 rdf:type owl:NamedIndividual ,
                :BRCA1 ,
                :Gene ;
       :hasLoFMutation :BRCA1_p.C61G .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA1_p.C61G
:BRCA1_p.C61G rdf:type owl:NamedIndividual ,
                       :Mutation ;
              :downregulatesPathway :Defective_Homologous_Recombination_Repair ;
              :hasEffect :LoF ;
              rdfs:label "BRCA1 p.C61G" .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA2
:BRCA2 rdf:type owl:NamedIndividual ,
                :BRCA2 ,
                :Gene ;
       :hasLoFMutation :BRCA2_p.Y3308Ter .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA2_p.Y3308Ter
:BRCA2_p.Y3308Ter rdf:type owl:NamedIndividual ,
                           :Mutation ;
                  :downregulatesPathway :Defective_Homologous_Recombination_Repair ;
                  :hasEffect :LoF ;
                  rdfs:label "BRCA2 p.Y3308*" .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Cell_Proliferation_due_to_TP53_Loss
:Cell_Proliferation_due_to_TP53_Loss rdf:type owl:NamedIndividual ,
                                              :Ki-67-related_pathway ,
                                              :Pathway ;
                                     rdfs:label "Cell Proliferation due to TP53 Loss" .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Constitutive_Signaling_by_AKT1_E17K_in_Cancer
:Constitutive_Signaling_by_AKT1_E17K_in_Cancer rdf:type owl:NamedIndividual ,
                                                        :ER-related_pathway ,
                                                        :Pathway ;
                                               rdfs:label "Constitutive Signaling by AKT1 E17K in Cancer" .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Constitutive_Signaling_by_Aberrant_PI3K_in_Cancer
:Constitutive_Signaling_by_Aberrant_PI3K_in_Cancer rdf:type owl:NamedIndividual ,
                                                            :ER-related_pathway ,
                                                            :Pathway ;
