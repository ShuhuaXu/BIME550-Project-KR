@prefix : <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5> a owl:Ontology .

:Basal a owl:Class ;
    rdfs:subClassOf :BreastCancerSubType ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :ER-Normal :HER2-Normal :Patient [ a owl:Class ;
                        owl:unionOf ( [ a owl:Restriction ;
                                    owl:onProperty :hasLoF ;
                                    owl:someValuesFrom :BRCA1 ] [ a owl:Restriction ;
                                    owl:onProperty :hasLoF ;
                                    owl:someValuesFrom :BRCA2 ] [ a owl:Restriction ;
                                    owl:onProperty :hasLoF ;
                                    owl:someValuesFrom :TP53 ] [ a owl:Restriction ;
                                    owl:onProperty :hasUpregulatedPathway ;
                                    owl:someValuesFrom :Ki-67-related_pathway ] ) ] ) ] .

:Her2 a owl:Class ;
    rdfs:subClassOf :BreastCancerSubType ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :ER-Normal :Patient [ a owl:Restriction ;
                        owl:onProperty :hasUpregulatedPathway ;
                        owl:someValuesFrom :HER2-related_pathway ] ) ] .

:LumA a owl:Class ;
    rdfs:subClassOf :BreastCancerSubType ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :HER2-Normal :Ki-67-Normal :Patient [ a owl:Restriction ;
                        owl:onProperty :hasUpregulatedPathway ;
                        owl:someValuesFrom :ER-related_pathway ] ) ] .

:LumB a owl:Class ;
    rdfs:subClassOf :BreastCancerSubType ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Patient [ a owl:Class ;
                        owl:unionOf ( [ a owl:Restriction ;
                                    owl:onProperty :hasUpregulatedPathway ;
                                    owl:someValuesFrom :HER2-related_pathway ] [ a owl:Restriction ;
                                    owl:onProperty :hasUpregulatedPathway ;
                                    owl:someValuesFrom :Ki-67-related_pathway ] ) ] [ a owl:Restriction ;
                        owl:onProperty :hasUpregulatedPathway ;
                        owl:someValuesFrom :ER-related_pathway ] ) ] .

:Normal a owl:Class ;
    rdfs:subClassOf :BreastCancerSubType ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :ER-Normal :HER2-Normal :Ki-67-Normal :Patient [ a owl:Restriction ;
                        owl:hasValue :BRCA1_p.C61G ;
                        owl:onProperty :notHasMutation ] [ a owl:Restriction ;
                        owl:hasValue :BRCA2_p.Y3308Ter ;
                        owl:onProperty :notHasMutation ] ) ] .

