:Patient a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom :PathwayCategory ;
            owl:onProperty :hasUpregulatedPathway ] .

[] a owl:AllDisjointClasses ;
    owl:members ( :DNA_Repair_Pathway :ER-related_pathway :HER2-related_pathway :Ki-67-related_pathway :PR-related_pathway ) .

[] a owl:AllDisjointProperties ;
    owl:members ( <http://www.semanticweb.org/owl/owlapi/turtle#hasDownregulatedPathway> <http://www.semanticweb.org/owl/owlapi/turtle#hasNormallyRegulatedPathway> <http://www.semanticweb.org/owl/owlapi/turtle#hasUpregulatedPathway> ) .

