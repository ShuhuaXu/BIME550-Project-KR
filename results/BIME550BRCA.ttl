@prefix : <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/> .

<http://www.semanticweb.org/kevinlee/ontologies/2026/1/BIME550BRCA> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/downregulatesPathway
:downregulatesPathway rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty ;
                      rdfs:domain [ rdf:type owl:Restriction ;
                                    owl:onProperty :downregulatesPathway ;
                                    owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation>
                                  ] ;
                      rdfs:range [ rdf:type owl:Restriction ;
                                   owl:onProperty :downregulatesPathway ;
                                   owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway>
                                 ] ;
                      owl:propertyDisjointWith :upregulatesPathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasDownregulatedPathway
:hasDownregulatedPathway rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty ;
                         rdfs:domain [ rdf:type owl:Restriction ;
                                       owl:onProperty :hasDownregulatedPathway ;
                                       owl:someValuesFrom :Patient
                                     ] ;
                         rdfs:range [ rdf:type owl:Restriction ;
                                      owl:onProperty :hasEffect ;
                                      owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway>
                                    ] ;
                         owl:propertyDisjointWith :hasUpregulatedPathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasEffect
:hasEffect rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           rdfs:domain [ rdf:type owl:Restriction ;
                         owl:onProperty :hasEffect ;
                         owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation>
                       ] ;
           rdfs:range [ rdf:type owl:Restriction ;
                        owl:onProperty :hasEffect ;
                        owl:someValuesFrom :Mutation_Effect
                      ] .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasGoF
:hasGoF rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :hasMutation ,
                           owl:topObjectProperty ;
        rdfs:domain [ rdf:type owl:Restriction ;
                      owl:onProperty :hasGoF ;
                      owl:someValuesFrom :Patient
                    ] ;
        rdfs:range [ rdf:type owl:Restriction ;
                     owl:onProperty :hasGoF ;
                     owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene>
                   ] .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasLoF
:hasLoF rdf:type owl:ObjectProperty ;
        rdfs:subPropertyOf :hasMutation ,
                           owl:topObjectProperty ;
        rdfs:domain [ rdf:type owl:Restriction ;
                      owl:onProperty :hasLoF ;
                      owl:someValuesFrom :Patient
                    ] ;
        rdfs:range [ rdf:type owl:Restriction ;
                     owl:onProperty :hasLoF ;
                     owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene>
                   ] .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasMutation
:hasMutation rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf owl:topObjectProperty ;
             rdfs:domain [ rdf:type owl:Restriction ;
                           owl:onProperty :hasMutation ;
                           owl:someValuesFrom :Patient
                         ] .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/hasUpregulatedPathway
:hasUpregulatedPathway rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdfs:domain [ rdf:type owl:Restriction ;
                                     owl:onProperty :hasUpregulatedPathway ;
                                     owl:someValuesFrom :Patient
                                   ] ;
                       rdfs:range [ rdf:type owl:Restriction ;
                                    owl:onProperty :hasUpregulatedPathway ;
                                    owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway>
                                  ] .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/upregulatesPathway
:upregulatesPathway rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty ;
                    rdfs:domain [ rdf:type owl:Restriction ;
                                  owl:onProperty :upregulatesPathway ;
                                  owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation>
                                ] ;
                    rdfs:range [ rdf:type owl:Restriction ;
                                 owl:onProperty :upregulatesPathway ;
                                 owl:someValuesFrom <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway>
                               ] .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/BIME550BRCA#Signaling_by_ERBB2_TMD/JMD_mutants
<http://www.semanticweb.org/kevinlee/ontologies/2026/1/BIME550BRCA#Signaling_by_ERBB2_TMD/JMD_mutants> rdf:type owl:Class ;
                                                                                                       rdfs:subClassOf :HER2-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType
<http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene
<http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation
<http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway
<http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA1
:BRCA1 rdf:type owl:Class ;
       rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/BRCA2
:BRCA2 rdf:type owl:Class ;
       rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Basal
:Basal rdf:type owl:Class ;
       owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                  [ rdf:type owl:Class ;
                                                    owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasLoF ;
                                                                    owl:someValuesFrom :BRCA1
                                                                  ]
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty :hasLoF ;
                                                                    owl:someValuesFrom :BRCA2
                                                                  ]
                                                                )
                                                  ]
                                                  [ rdf:type owl:Class ;
                                                    owl:complementOf [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :hasUpregulatedPathway ;
                                                                       owl:someValuesFrom :ER-related_pathway
                                                                     ]
                                                  ]
                                                  [ rdf:type owl:Class ;
                                                    owl:complementOf [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :hasUpregulatedPathway ;
                                                                       owl:someValuesFrom :HER2-related_pathway
                                                                     ]
                                                  ]
                                                  [ rdf:type owl:Class ;
                                                    owl:complementOf [ rdf:type owl:Restriction ;
                                                                       owl:onProperty :hasUpregulatedPathway ;
                                                                       owl:someValuesFrom :PR-related_pathway
                                                                     ]
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasLoF ;
                                                    owl:someValuesFrom :TP53
                                                  ]
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty :hasUpregulatedPathway ;
                                                    owl:someValuesFrom :Ki-67-related_pathway
                                                  ]
                                                ) ;
                             rdf:type owl:Class
                           ] ;
       rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Constitutive_Signaling_by_AKT1_E17K_in_Cancer
:Constitutive_Signaling_by_AKT1_E17K_in_Cancer rdf:type owl:Class ;
                                               rdfs:subClassOf :ER-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Constitutive_Signaling_by_Aberrant_PI3K_in_Cancer
:Constitutive_Signaling_by_Aberrant_PI3K_in_Cancer rdf:type owl:Class ;
                                                   rdfs:subClassOf :ER-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Defective_translocation_of_RB1_mutants_to_the_nucleus
:Defective_translocation_of_RB1_mutants_to_the_nucleus rdf:type owl:Class ;
                                                       rdfs:subClassOf :ER-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/ER
:ER rdf:type owl:Class ;
    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/ER-related_pathway
:ER-related_pathway rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/ERBB2
:ERBB2 rdf:type owl:Class ;
       owl:equivalentClass :HER2 ;
       rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/HER2
:HER2 rdf:type owl:Class ;
      rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/HER2-related_pathway
:HER2-related_pathway rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Her2
:Her2 rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                 [ rdf:type owl:Class ;
                                                   owl:unionOf ( [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                          owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty :hasUpregulatedPathway ;
                                                                                                             owl:someValuesFrom :ER-related_pathway
                                                                                                           ]
                                                                                        ]
                                                                                        [ rdf:type owl:Class ;
                                                                                          owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty :hasUpregulatedPathway ;
                                                                                                             owl:someValuesFrom :PR-related_pathway
                                                                                                           ]
                                                                                        ]
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty :hasUpregulatedPathway ;
                                                                                          owl:someValuesFrom :Ki-67-related_pathway
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
                                                                 [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                          owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty :hasUpregulatedPathway ;
                                                                                                             owl:someValuesFrom :Ki-67-related_pathway
                                                                                                           ]
                                                                                        ]
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty :hasUpregulatedPathway ;
                                                                                          owl:someValuesFrom :ER-related_pathway
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
                                                               )
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :HER2-related_pathway
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Ki-67
:Ki-67 rdf:type owl:Class ;
       rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Ki-67-related_pathway
:Ki-67-related_pathway rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Loss_of_function_of_TP53_in_cancer_due_to_loss_of_tetramerization_ability
:Loss_of_function_of_TP53_in_cancer_due_to_loss_of_tetramerization_ability rdf:type owl:Class ;
                                                                           rdfs:subClassOf :ER-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/LumA
:LumA rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                 [ rdf:type owl:Class ;
                                                   owl:complementOf [ rdf:type owl:Restriction ;
                                                                      owl:onProperty :hasUpregulatedPathway ;
                                                                      owl:someValuesFrom :Ki-67-related_pathway
                                                                    ]
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :ER-related_pathway
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :PR-related_pathway
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/LumB
:LumB rdf:type owl:Class ;
      owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                 [ rdf:type owl:Class ;
                                                   owl:unionOf ( [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                          owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty :hasUpregulatedPathway ;
                                                                                                             owl:someValuesFrom :HER2-related_pathway
                                                                                                           ]
                                                                                        ]
                                                                                        [ rdf:type owl:Class ;
                                                                                          owl:complementOf [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty :hasUpregulatedPathway ;
                                                                                                             owl:someValuesFrom :PR-related_pathway
                                                                                                           ]
                                                                                        ]
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty :hasUpregulatedPathway ;
                                                                                          owl:someValuesFrom :Ki-67-related_pathway
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :hasUpregulatedPathway ;
                                                                   owl:someValuesFrom :HER2-related_pathway
                                                                 ]
                                                               )
                                                 ]
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty :hasUpregulatedPathway ;
                                                   owl:someValuesFrom :ER-related_pathway
                                                 ]
                                               ) ;
                            rdf:type owl:Class
                          ] ;
      rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Mutation_Effect
:Mutation_Effect rdf:type owl:Class ;
                 rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Normal
:Normal rdf:type owl:Class ;
        owl:equivalentClass [ owl:intersectionOf ( :Patient
                                                   [ rdf:type owl:Class ;
                                                     owl:complementOf [ rdf:type owl:Class ;
                                                                        owl:unionOf ( :Basal
                                                                                      :Her2
                                                                                      :LumA
                                                                                      :LumB
                                                                                    )
                                                                      ]
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
        rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#BreastCancerSubType> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PR
:PR rdf:type owl:Class ;
    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PR-related_pathway
:PR-related_pathway rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Pathway> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/PTEN_Loss_of_Function_in_Cancer
:PTEN_Loss_of_Function_in_Cancer rdf:type owl:Class ;
                                 rdfs:subClassOf :ER-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Patient
:Patient rdf:type owl:Class .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/SMAD4_MH2_Domain_Mutants_in_Cancer
:SMAD4_MH2_Domain_Mutants_in_Cancer rdf:type owl:Class ;
                                    rdfs:subClassOf :ER-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Signaling_by_ERBB2_ECD_mutants
:Signaling_by_ERBB2_ECD_mutants rdf:type owl:Class ;
                                rdfs:subClassOf :HER2-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Signaling_by_ERBB2_KD_Mutants
:Signaling_by_ERBB2_KD_Mutants rdf:type owl:Class ;
                               rdfs:subClassOf :HER2-related_pathway .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/TP53
:TP53 rdf:type owl:Class ;
      rdfs:subClassOf <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/GoF
:GoF rdf:type owl:NamedIndividual ,
              <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> ,
              :Mutation_Effect .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/LoF
:LoF rdf:type owl:NamedIndividual ,
              <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> ,
              :Mutation_Effect .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Others
:Others rdf:type owl:NamedIndividual ,
                 <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Mutation> .


###  http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5/Partial_LoF
:Partial_LoF rdf:type owl:NamedIndividual ,
                      :Mutation_Effect .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Basal
                :Her2
                :LumA
                :LumB
                :Normal
              )
] .


#################################################################
#    Rules
#################################################################

:pt rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:g rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:m rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:p rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "S4" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :Patient ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :pt
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.semanticweb.org/kevinlee/ontologies/2026/1/untitled-ontology-5#Gene> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :g
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasMutation ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :pt ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :m
